---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Get in touch with the OHS Chinese Culture Club.">
	<div class="max-w-2xl mx-auto text-center space-y-12 py-12">
		<header class="space-y-6 reveal-on-load animate-fade-in-up">
			<h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Contact <span class="text-cinnabar italic">Us</span></h1>
			<div class="w-16 h-px bg-cinnabar mx-auto"></div>
		</header>

		<div class="bg-white border border-ink/10 rounded-sm p-10 space-y-6 reveal-on-load animate-fade-in-up delay-100">
			<svg class="w-12 h-12 text-cinnabar mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
			
			<h2 class="text-2xl font-bold text-ink">We'd love to hear from you!</h2>
			
			<p class="text-lg text-ink/80 leading-relaxed">
				If you have any questions about the club, upcoming events, or how to get involved, the best way to reach us is by contacting one of our club officers directly.
			</p>

			<div class="pt-6">
				<a href="/officers" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-sm text-white bg-cinnabar hover:bg-cinnabar/90 transition-colors">
					View Club Officers Directory
				</a>
			</div>
		</div>

		<p class="text-ink/60 text-sm reveal-on-load animate-fade-in-up delay-200">
			Alternatively, you can always drop by <strong>Room D230</strong> on our meeting days!
		</p>
	</div>
</Layout>
