---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

const allOfficers = await getCollection('officers');
const sortedOfficers = allOfficers.sort((a, b) => a.data.order - b.data.order);

const officersWithContent = await Promise.all(
  sortedOfficers.map(async (officer) => {
    const { Content } = await render(officer);
    return { ...officer, Content };
  })
);

// 按学年分组，学年降序排列（最新在前）
const allAlumni = await getCollection('alumni');
const alumniByYear = allAlumni
  .sort((a, b) => a.data.order - b.data.order)
  .reduce((acc, person) => {
    (acc[person.data.year] ??= []).push(person);
    return acc;
  }, {} as Record<string, typeof allAlumni>);
const sortedYears = Object.keys(alumniByYear).sort((a, b) => {
  if (a === 'Founders') return 1;
  if (b === 'Founders') return -1;
  return b.localeCompare(a);
});
---

<Layout title="Club Officers" description="Meet the leadership team behind the OHS Chinese Culture Club.">
	<div class="space-y-16">
		<header class="text-center space-y-6 reveal-on-load animate-fade-in-up">
			<h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Club <span class="text-cinnabar italic">Officers</span></h1>
			<p class="text-lg text-ink/70 max-w-2xl mx-auto">
				Meet the dedicated team working behind the scenes to make our club events possible. Feel free to reach out to any of us!
			</p>
			<div class="w-16 h-px bg-cinnabar mx-auto"></div>
		</header>

		<!-- Magazine Style Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 reveal-on-load animate-fade-in-up delay-200">
			{officersWithContent.map((officer) => (
				<div class="group flex flex-col">
					<div class="w-full aspect-[4/5] bg-ink/5 mb-6 overflow-hidden relative border border-ink/10">
						{officer.data.photo ? (
							<img
								src={officer.data.photo}
								alt={officer.data.name}
								class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
							/>
						) : (
							<div class="absolute inset-0 flex flex-col items-center justify-center bg-[#f7f5f0]">
								<div class="w-12 h-12 border border-ink/20 rotate-45 flex items-center justify-center mb-4">
									<div class="w-8 h-8 border border-ink/20"></div>
								</div>
								<span class="text-ink/30 text-xs tracking-[0.3em] uppercase font-sans">Portrait</span>
							</div>
						)}
						<div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/5 transition-colors duration-300"></div>
					</div>

					<div class="flex-grow flex flex-col pt-4">
						<div class="mb-1">
							<h2 class="text-2xl font-bold text-ink">{officer.data.name}</h2>
						</div>

						<p class="text-cinnabar font-medium mb-4 uppercase tracking-wider text-sm">{officer.data.position}</p>

						<div class="text-ink/80 text-sm leading-relaxed prose prose-sm prose-stone mb-6 flex-grow">
							<officer.Content />
						</div>

						<a data-email={btoa(officer.data.email)} href="#" class="email-link inline-flex items-center gap-2 text-ink/60 hover:text-cinnabar text-sm transition-colors mt-auto pt-4 border-t border-ink/10">
							<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
							<span class="email-text">Send Email</span>
						</a>
					</div>
				</div>
			))}
		</div>

		<!-- 历届领导 Legacy Section -->
		{sortedYears.length > 0 && (
			<section class="reveal-on-load animate-fade-in-up delay-300 space-y-12">
				<div class="text-center space-y-4">
					<h2 class="text-3xl sm:text-4xl font-bold tracking-tight">Past <span class="text-cinnabar italic">Leaders</span></h2>
					<p class="text-ink/60 max-w-xl mx-auto">Honoring those who helped build the club.</p>
					<div class="w-16 h-px bg-cinnabar mx-auto"></div>
				</div>

				{sortedYears.map((year) => (
					<div class="space-y-6">
						<!-- 学年标题 -->
						<div class="flex items-center gap-4">
							<span class="text-cinnabar font-bold tracking-widest text-sm uppercase">{year}</span>
							<div class="flex-1 h-px bg-ink/10"></div>
						</div>

						<!-- 紧凑网格 -->
						<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
							{alumniByYear[year].map((person) => (
								<div class="flex flex-col items-center text-center gap-3">
									<div class="w-full aspect-square bg-ink/5 overflow-hidden relative border border-ink/10">
										{person.data.photo ? (
											<img
												src={person.data.photo}
												alt={person.data.name}
												class="w-full h-full object-cover"
											/>
										) : (
											<div class="absolute inset-0 flex items-center justify-center bg-[#f7f5f0]">
												<div class="w-8 h-8 border border-ink/20 rotate-45"></div>
											</div>
										)}
									</div>
									<div>
										<p class="font-bold text-ink text-sm leading-tight">{person.data.name}</p>
										<p class="text-cinnabar text-xs uppercase tracking-wider mt-0.5">{person.data.position}</p>
									</div>
								</div>
							))}
						</div>
					</div>
				))}
			</section>
		)}
	</div>

<script>
  // 解码邮箱地址，防爬虫
  document.querySelectorAll('a.email-link[data-email]').forEach(el => {
    const email = atob((el as HTMLElement).dataset.email!);
    el.href = 'mailto:' + email;
    el.querySelector('.email-text')!.textContent = email;
  });
</script>
</Layout>
